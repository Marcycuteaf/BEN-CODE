<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0"
    ExtensionBundleId="com.bencode.qrbarcode"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="BEN CODE"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <ExtensionList>
        <Extension Id="com.bencode.qrbarcode.panel" Version="1.0.0" />
    </ExtensionList>

    <ExecutionEnvironment>
        <HostList>
            <!-- After Effects. 寬鬆涵蓋 CC 2019 ~ 2025+ -->
            <Host Name="AEFT" Version="[16.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>

    <DispatchInfoList>
        <Extension Id="com.bencode.qrbarcode.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/host.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--allow-file-access</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>BEN CODE — QR &amp; Barcode</Menu>
                    <Geometry>
                        <Size>
                            <Height>640</Height>
                            <Width>340</Width>
                        </Size>
                        <MinSize>
                            <Height>420</Height>
                            <Width>300</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>1400</Height>
                            <Width>700</Width>
                        </MaxSize>
                    </Geometry>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
